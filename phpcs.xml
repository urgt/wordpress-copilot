<?xml version="1.0"?>
<ruleset name="Data Query Assistant">
    <description>WordPress Coding Standards for Data Query Assistant plugin.</description>

    <!-- Scan these files/folders -->
    <file>.</file>

    <!-- Exclude vendor and generated files -->
    <exclude-pattern>./vendor/*</exclude-pattern>
    <exclude-pattern>./node_modules/*</exclude-pattern>

    <!-- WordPress coding standards rules -->
    <rule ref="WordPress">
        <!-- All classes use the DQA_ prefix; file names intentionally omit it for readability. -->
        <exclude name="WordPress.Files.FileName.InvalidClassFileName"/>
    </rule>

    <!-- PHP version requirement -->
    <config name="testVersion" value="8.0-"/>
</ruleset>
